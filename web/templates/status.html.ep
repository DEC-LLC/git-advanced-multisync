<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>System Status - git-advanced-multisync</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
  <style>
    :root { --brand-dark: #0f2b46; }
    .navbar { background-color: var(--brand-dark) !important; }
    .navbar-brand { font-weight: 700; }
    .stat-card { border-left: 4px solid #0d6efd; }
    .stat-card.green { border-left-color: #198754; }
    .stat-card.yellow { border-left-color: #ffc107; }
    .stat-card.red { border-left-color: #dc3545; }
    .stat-number { font-size: 1.8rem; font-weight: 700; color: var(--brand-dark); }
    footer { color: #6c757d; font-size: 0.85rem; }
  </style>
</head>
<body class="bg-light">
  <nav class="navbar navbar-expand-lg navbar-dark">
    <div class="container-fluid">
      <a class="navbar-brand" href="/"><i class="bi bi-arrow-repeat"></i> git-advanced-multisync</a>
      <div class="collapse navbar-collapse">
        <ul class="navbar-nav me-auto">
          <li class="nav-item"><a class="nav-link" href="/">Dashboard</a></li>
          <li class="nav-item"><a class="nav-link" href="/providers">Providers</a></li>
          <li class="nav-item"><a class="nav-link" href="/profiles">Profiles</a></li>
          <li class="nav-item"><a class="nav-link" href="/mappings">Mappings</a></li>
          <li class="nav-item"><a class="nav-link" href="/jobs">Jobs</a></li>
          <li class="nav-item"><a class="nav-link active" href="/status">Status</a></li>
        </ul>
        <span class="navbar-text text-light me-3">
          <i class="bi bi-person"></i> <%= $current_user->{username} %>
          (<%= $current_user->{role} %>)
        </span>
        <a class="nav-link text-light" href="/logout"><i class="bi bi-box-arrow-right"></i> Logout</a>
      </div>
    </div>
  </nav>

  <div class="container-fluid py-4">
    <h2 class="mb-4"><i class="bi bi-activity"></i> System Status</h2>

    <!-- Daemon Info -->
    <div class="row g-3 mb-4">
      <div class="col-md-3">
        <div class="card stat-card green h-100">
          <div class="card-body">
            <div class="text-muted small text-uppercase">Daemon</div>
            <div class="stat-number text-success"><i class="bi bi-check-circle"></i></div>
            <div>Running</div>
            <small class="text-muted">PID: <%= $$ %></small>
          </div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="card stat-card h-100">
          <div class="card-body">
            <div class="text-muted small text-uppercase">Uptime</div>
            % my $uptime_secs = time() - $start_time;
            % my $days = int($uptime_secs / 86400);
            % my $hours = int(($uptime_secs % 86400) / 3600);
            % my $mins = int(($uptime_secs % 3600) / 60);
            <div class="stat-number"><%= $days ? "${days}d " : "" %><%= "${hours}h ${mins}m" %></div>
            <small class="text-muted">Started: <%= scalar localtime($start_time) %></small>
          </div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="card stat-card h-100">
          <div class="card-body">
            <div class="text-muted small text-uppercase">Database</div>
            <div class="stat-number text-success"><i class="bi bi-database-check"></i></div>
            <div>Connected</div>
            <small class="text-muted">Size: <%= $db_size %></small>
          </div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="card stat-card h-100">
          <div class="card-body">
            <div class="text-muted small text-uppercase">Work Directory</div>
            <div class="stat-number"><%= $workdir_size %></div>
            <small class="text-muted"><%= $ENV{GITMSYNCD_WORKDIR} || '/tmp/gitmsyncd-workdir' %></small>
          </div>
        </div>
      </div>
    </div>

    <!-- Counts -->
    <div class="row g-3 mb-4">
      <div class="col-md-2">
        <div class="card stat-card green h-100">
          <div class="card-body text-center">
            <div class="text-muted small">Providers</div>
            <div class="stat-number"><%= $providers->{total} %></div>
            <small class="text-success"><%= $providers->{ok} %> connected</small>
          </div>
        </div>
      </div>
      <div class="col-md-2">
        <div class="card stat-card h-100">
          <div class="card-body text-center">
            <div class="text-muted small">Profiles</div>
            <div class="stat-number"><%= $profiles->{total} %></div>
            <small><%= $profiles->{enabled} %> enabled, <%= $profiles->{scheduled} %> scheduled</small>
          </div>
        </div>
      </div>
      <div class="col-md-2">
        <div class="card stat-card h-100">
          <div class="card-body text-center">
            <div class="text-muted small">Repo Mappings</div>
            <div class="stat-number"><%= $mappings->{total} %></div>
            <small><%= $mappings->{enabled} %> enabled</small>
          </div>
        </div>
      </div>
      <div class="col-md-2">
        <div class="card stat-card green h-100">
          <div class="card-body text-center">
            <div class="text-muted small">Jobs (success)</div>
            <div class="stat-number text-success"><%= $jobs_stats->{success} %></div>
          </div>
        </div>
      </div>
      <div class="col-md-2">
        <div class="card stat-card red h-100">
          <div class="card-body text-center">
            <div class="text-muted small">Jobs (failed)</div>
            <div class="stat-number text-danger"><%= $jobs_stats->{failed} %></div>
          </div>
        </div>
      </div>
      <div class="col-md-2">
        <div class="card stat-card yellow h-100">
          <div class="card-body text-center">
            <div class="text-muted small">Queued / Running</div>
            <div class="stat-number"><%= $jobs_stats->{queued} + $jobs_stats->{running} %></div>
          </div>
        </div>
      </div>
    </div>

    <div class="row g-3">
      <!-- Scheduled Syncs -->
      <div class="col-md-6">
        <div class="card">
          <div class="card-header bg-white"><h6 class="mb-0"><i class="bi bi-clock-history"></i> Scheduled Syncs</h6></div>
          <div class="card-body p-0">
            <table class="table table-sm table-striped mb-0">
              <thead class="table-light"><tr><th>Profile</th><th>Interval</th><th>Next Sync</th><th>Last Synced</th><th>Lock</th></tr></thead>
              <tbody>
                % if (@{$next_syncs}) {
                  % for my $s (@{$next_syncs}) {
                  <tr>
                    <td><strong><%= $s->{name} %></strong></td>
                    <td><%= $s->{sync_interval_minutes} %>min</td>
                    <td><small><%= $s->{next_sync_at} // 'not set' %></small></td>
                    <td><small><%= $s->{last_synced_at} // 'never' %></small></td>
                    <td>
                      % if ($s->{sync_locked}) {
                        <span class="badge bg-warning text-dark"><i class="bi bi-lock"></i> <%= $s->{sync_locked_by} // 'locked' %></span>
                      % } else {
                        <span class="text-success"><i class="bi bi-unlock"></i></span>
                      % }
                    </td>
                  </tr>
                  % }
                % } else {
                  <tr><td colspan="5" class="text-muted text-center py-3">No scheduled profiles. Set an interval on a profile to enable.</td></tr>
                % }
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Users -->
      <div class="col-md-6">
        <div class="card">
          <div class="card-header bg-white"><h6 class="mb-0"><i class="bi bi-people"></i> Users</h6></div>
          <div class="card-body p-0">
            <table class="table table-sm table-striped mb-0">
              <thead class="table-light"><tr><th>Username</th><th>Role</th><th>Enabled</th><th>Last Login</th></tr></thead>
              <tbody>
                % for my $u (@{$users}) {
                <tr>
                  <td><strong><%= $u->{username} %></strong></td>
                  <td><span class="badge <%= $u->{role} eq 'admin' ? 'bg-primary' : 'bg-secondary' %>"><%= $u->{role} %></span></td>
                  <td><%= $u->{enabled} ? 'Yes' : 'No' %></td>
                  <td><small><%= $u->{last_login_at} // 'never' %></small></td>
                </tr>
                % }
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>

    <!-- Workers -->
    <div class="card mt-3">
      <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <h6 class="mb-0"><i class="bi bi-cpu"></i> Workers</h6>
        % if ($is_admin) {
        <button class="btn btn-sm btn-outline-primary" onclick="startWorker()"><i class="bi bi-plus-circle"></i> Start Worker</button>
        % }
      </div>
      <div class="card-body p-0">
        <table class="table table-sm table-striped mb-0">
          <thead class="table-light"><tr><th>Set</th><th>Host</th><th>PID</th><th>Health</th><th>Forks</th><th>Started</th><th>Heartbeat</th>
          % if ($is_admin) {
            <th>Actions</th>
          % }
          </tr></thead>
          <tbody>
            % if (@{$workers}) {
              % for my $w (@{$workers}) {
              <tr>
                <td><strong><%= $w->{worker_set} %></strong></td>
                <td><%= $w->{hostname} %></td>
                <td><%= $w->{pid} %></td>
                <td>
                  % my $h = $w->{health};
                  % my $paused = $w->{paused} || $w->{status} eq 'paused';
                  % if ($paused) {
                    <span class="badge bg-info">paused</span>
                  % } else {
                    <span class="badge bg-<%= $h eq 'healthy' ? 'success' : $h eq 'stale' ? 'warning' : 'danger' %>"><%= $h %></span>
                  % }
                </td>
                <td><%= $w->{active_forks} %></td>
                <td><small><%= $w->{started_at} %></small></td>
                <td><small><%= $w->{last_heartbeat_at} %></small></td>
                % if ($is_admin) {
                <td>
                  % if ($w->{status} eq 'running' || $w->{status} eq 'paused') {
                    % if ($paused) {
                      <button class="btn btn-sm btn-outline-success py-0 px-1" onclick="workerAction(<%= $w->{id} %>, 'resume')" title="Resume"><i class="bi bi-play-fill"></i></button>
                    % } else {
                      <button class="btn btn-sm btn-outline-warning py-0 px-1" onclick="workerAction(<%= $w->{id} %>, 'pause')" title="Pause"><i class="bi bi-pause-fill"></i></button>
                    % }
                    <button class="btn btn-sm btn-outline-danger py-0 px-1" onclick="workerAction(<%= $w->{id} %>, 'stop')" title="Stop"><i class="bi bi-stop-fill"></i></button>
                  % } else {
                    <span class="text-muted"><small><%= $w->{status} %></small></span>
                  % }
                </td>
                % }
              </tr>
              % }
            % } else {
              <tr><td colspan="<%= $is_admin ? 8 : 7 %>" class="text-muted text-center py-3">No workers registered. Click "Start Worker" above or workers will auto-start on next boot.</td></tr>
            % }
          </tbody>
        </table>
      </div>
    </div>

    <!-- Recent Jobs -->
    <div class="card mt-3">
      <div class="card-header bg-white"><h6 class="mb-0"><i class="bi bi-journal-text"></i> Recent Jobs</h6></div>
      <div class="card-body p-0">
        <table class="table table-sm table-striped mb-0">
          <thead class="table-light"><tr><th>ID</th><th>Profile</th><th>Status</th><th>Started</th><th>Finished</th><th>Message</th></tr></thead>
          <tbody>
            % for my $j (@{$recent_jobs}) {
            <tr>
              <td><%= $j->{id} %></td>
              <td><%= $j->{profile_name} // '?' %></td>
              <td>
                % my $s = $j->{status};
                <span class="badge bg-<%= $s eq 'success' ? 'success' : $s eq 'failed' ? 'danger' : $s eq 'running' ? 'primary' : 'secondary' %>"><%= $s %></span>
              </td>
              <td><small><%= $j->{started_at} // '--' %></small></td>
              <td><small><%= $j->{finished_at} // '--' %></small></td>
              <td><small class="text-muted"><%= $j->{message} // '' %></small></td>
            </tr>
            % }
          </tbody>
        </table>
      </div>
    </div>

    <!-- Resource Warning — shown when multiple workers on same host -->
    % my %host_worker_count;
    % for my $w (@{$workers}) {
    %   $host_worker_count{$w->{hostname}}++ if $w->{status} eq 'running';
    % }
    % my $this_host = `hostname` =~ s/\n//r;
    % my $local_count = $host_worker_count{$this_host} || 0;
    % if ($local_count > 1) {
    <div class="alert alert-warning mt-3" role="alert">
      <i class="bi bi-exclamation-triangle"></i>
      <strong>Multi-instance warning:</strong> <%= $local_count %> workers running on this host (<%= $this_host %>).
      Each worker forks child processes for repo sync. Ensure this host has adequate CPU (4+ cores),
      memory (4+ GB), disk I/O, and network bandwidth. Hosts with limited resources should run
      one instance locally and deploy additional instances as containers on separate hosts.
    </div>
    % }

    <!-- Host Resources -->
    % my $cpu_count = 0;
    % if (open my $cpuinfo, '<', '/proc/cpuinfo') {
    %   $cpu_count++ while <$cpuinfo> =~ /^processor/;
    %   close $cpuinfo;
    % }
    % my ($load1, $load5, $load15) = split /\s+/, (`cat /proc/loadavg 2>/dev/null` || '0 0 0');
    % my $mem_total_mb = 0; my $mem_avail_mb = 0;
    % if (open my $memfh, '<', '/proc/meminfo') {
    %   while (<$memfh>) {
    %     $mem_total_mb = int($1/1024) if /^MemTotal:\s+(\d+)/;
    %     $mem_avail_mb = int($1/1024) if /^MemAvailable:\s+(\d+)/;
    %   }
    %   close $memfh;
    % }

    <!-- System Info -->
    <div class="card mt-3">
      <div class="card-header bg-white"><h6 class="mb-0"><i class="bi bi-info-circle"></i> System Info</h6></div>
      <div class="card-body">
        <div class="row">
          <div class="col-md-4">
            <small class="text-muted">Version</small><br>
            <strong>0.3.0</strong>
          </div>
          <div class="col-md-4">
            <small class="text-muted">Perl</small><br>
            <strong><%= $^V %></strong>
          </div>
          <div class="col-md-4">
            <small class="text-muted">Worker Poll Interval</small><br>
            <strong>5 seconds</strong>
          </div>
        </div>
        <div class="row mt-2">
          <div class="col-md-4">
            <small class="text-muted">Hostname</small><br>
            <strong><%= `hostname` =~ s/\n//r %></strong>
          </div>
          <div class="col-md-4">
            <small class="text-muted">OS</small><br>
            <strong><%= $^O %></strong>
          </div>
          <div class="col-md-4">
            <small class="text-muted">Stale Lock Timeout</small><br>
            <strong>30 minutes</strong>
          </div>
        </div>
        <div class="row mt-2">
          <div class="col-md-3">
            <small class="text-muted">CPU Cores</small><br>
            <strong><%= $cpu_count %></strong>
          </div>
          <div class="col-md-3">
            <small class="text-muted">Load Average (1/5/15m)</small><br>
            <strong class="<%= $load1 >= $cpu_count * 0.8 ? 'text-danger' : '' %>"><%= "$load1 / $load5 / $load15" %></strong>
          </div>
          <div class="col-md-3">
            <small class="text-muted">Memory</small><br>
            <strong class="<%= $mem_avail_mb < 512 ? 'text-danger' : $mem_avail_mb < 1024 ? 'text-warning' : '' %>"><%= $mem_avail_mb %> MB free</strong>
            <small class="text-muted">/ <%= $mem_total_mb %> MB</small>
          </div>
          <div class="col-md-3">
            <small class="text-muted">Workdir</small><br>
            <strong><%= $workdir_size %></strong>
            <small class="text-muted"><%= $ENV{GITMSYNCD_WORKDIR} || '/tmp/gitmsyncd-workdir' %></small>
          </div>
        </div>
      </div>
    </div>

  </div>

  <footer class="text-center py-3">
    git-advanced-multisync &mdash; DEC-LLC
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script>
  function startWorker() {
    const set = prompt('Worker set name (or "default" for all profiles):', 'default');
    if (!set) return;
    fetch('/api/workers/start', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ set: set })
    }).then(r => r.json()).then(data => {
      if (data.ok) {
        alert('Worker starting for set "' + set + '". It will appear in the table within a few seconds.');
        setTimeout(() => location.reload(), 3000);
      } else {
        alert('Error: ' + (data.error || 'unknown'));
      }
    }).catch(e => alert('Request failed: ' + e));
  }

  function workerAction(id, action) {
    const labels = { stop: 'Stop', pause: 'Pause', resume: 'Resume' };
    if (action === 'stop' && !confirm('Stop this worker? Running jobs will finish first.')) return;
    fetch('/api/workers/' + id + '/' + action, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' }
    }).then(r => r.json()).then(data => {
      if (data.ok) {
        setTimeout(() => location.reload(), 1500);
      } else {
        alert('Error: ' + (data.error || 'unknown'));
      }
    }).catch(e => alert('Request failed: ' + e));
  }
  </script>
</body>
</html>
