# Copy to ~/.config/github-gitlab-mirror.env and chmod 600

# Required GitLab settings
GITLAB_TOKEN="glpat-xxx"
GITLAB_URL="https://gitlab.yourdomain.tld"
GITLAB_GROUP="your-group/subgroup"

# Repo source mode: api or list
REPO_SOURCE_MODE="api"

# If REPO_SOURCE_MODE=api
GITHUB_TOKEN="ghp_xxx"
SOURCE_TYPE="user"        # user or org
# SOURCE_NAME="your-org"  # required if SOURCE_TYPE=org

# If REPO_SOURCE_MODE=list
# REPO_LIST_FILE="/home/madhav/.config/github-repos.list"
# List format supports:
# - owner/repo
# - repo_name|git@github.com:owner/repo.git
# - repo_name|https://github.com/owner/repo.git

# Protocol toggles
GITHUB_CLONE_PROTOCOL="ssh"   # ssh or https
GITLAB_PUSH_PROTOCOL="https"  # ssh or https

# Optional SSH keys
# GITHUB_SSH_KEY="/home/madhav/.ssh/id_github_mdiwan_diwanconsulting_ed25519"
# GITLAB_SSH_KEY="/home/madhav/.ssh/id_gitlab_ed25519"

# Optional SSH host/port override for GitLab push
# GITLAB_SSH_HOST="gitlab.decllc.biz"
# GITLAB_SSH_PORT="22"

# Optional
WORKDIR="/tmp/github-gitlab-mirror"
DRY_RUN="false"
